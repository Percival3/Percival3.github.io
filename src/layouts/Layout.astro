---
import '../styles/global.css';
import '../styles/plum-branch.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A minimalist personal website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts for Hand-drawn display text and Serif body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Noto+Serif+SC:wght@300;400;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class:list={['antialiased', 'min-h-screen', isHome ? 'is-home' : 'is-subpage']}>
    <!-- Shared wind filter for ink-grove (body::after); kept in layout so ClientRouter swaps cannot drop it. -->
    <svg aria-hidden="true" class="grove-wind-defs">
      <defs>
        <filter
          id="grove-wind"
          x="-12%"
          y="-12%"
          width="124%"
          height="124%"
          color-interpolation-filters="sRGB"
        >
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.012 0.018"
            numOctaves="2"
            seed="3"
            result="noise"
          >
            <animate
              attributeName="baseFrequency"
              dur="11s"
              values="0.010 0.016;0.014 0.022;0.011 0.015;0.013 0.020;0.010 0.016"
              repeatCount="indefinite"
            />
          </feTurbulence>
          <feDisplacementMap
            in="SourceGraphic"
            in2="noise"
            scale="6.5"
            xChannelSelector="R"
            yChannelSelector="G"
          >
            <animate
              attributeName="scale"
              dur="9s"
              values="4.5;8.5;5.5;7.5;4.5"
              repeatCount="indefinite"
            />
          </feDisplacementMap>
        </filter>
      </defs>
    </svg>
    <div class="site-content">
      <slot />
    </div>
    <script is:inline>
      const resetViewportChrome = () => {
        document.documentElement.style.backgroundImage = 'none';
        document.body.style.backgroundImage = 'none';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        const home = location.pathname === '/' || location.pathname === '';
        document.body.classList.toggle('is-home', home);
        document.body.classList.toggle('is-subpage', !home);
      };
      document.addEventListener('astro:after-swap', resetViewportChrome);
      document.addEventListener('astro:page-load', resetViewportChrome);
    </script>
  </body>
</html>
