---
interface Props {
  href?: string;
  label?: string;
}

const { href = '/', label = 'Return' } = Astro.props;
---

<a
  href={href}
  class="group absolute top-8 left-6 flex flex-col items-center justify-center transition-transform hover:-translate-x-2 z-10"
>
  <div class="w-8 h-12 border-2 border-ink-main border-b-0 relative bg-bg-paper">
    <div class="absolute right-1 top-1/2 w-1 h-1 bg-ink-main rounded-full"></div>
  </div>
  <span class="font-[Caveat] text-lg text-ink-muted mt-1 opacity-0 group-hover:opacity-100 transition-opacity">
    {label}
  </span>
</a>
