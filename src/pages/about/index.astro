---
import Layout from '../../layouts/Layout.astro';
import HandDrawnDivider from '../../components/HandDrawnDivider';
import BackDoor from '../../components/BackDoor.astro';
---

<Layout title="About | Zhong Pengchen">
  <main class="subpage-surface w-full min-h-screen max-w-3xl mx-auto px-6 py-16 relative">
    
    <BackDoor />

    <header class="subpage-title text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-wide mb-4">About Me / 关于我</h1>
      <p class="font-[Caveat] text-2xl text-ink-muted">A brief introduction.</p>
    </header>

    <HandDrawnDivider client:load />

    <article class="prose prose-lg mt-12 w-full max-w-none">
      <p>
        Hi, I'm <strong>Zhong Pengchen</strong>. Welcome to my personal site.
      </p>
      
      <p>
        你好，我是钟朋辰。欢迎来到我的个人主页。
      </p>

      <h2>Experience</h2>
      <ul class="list-none pl-0">
        <li class="mb-2"><span class="font-mono text-ink-muted mr-4">2026 - 现今</span> <strong>Fudan University</strong> /复旦大学  Phd(Economics) </li> 
        <li class="mb-2"><span class="font-mono text-ink-muted mr-4">2022 - 2026</span> <strong>Peking University</strong> /北京大学 BA(Economics & Philosophy)  </li> 
      </ul>

      <h2>Contact</h2>
      <p>
        You can reach me via email at <a href="mailto:hello@example.com">hello@example.com</a> or find me on <a href="#">Twitter</a> and <a href="#">GitHub</a>.
      </p>
      
      <div class="mt-20 mb-8">
        <HandDrawnDivider client:load />
        <div class="text-center mt-8 flex flex-col gap-3 not-prose">
          <a href="/" class="font-[Caveat] text-2xl text-ink-muted no-underline hover:text-ink-main hover:bg-transparent transition-colors">Return to the courtyard</a>
          <a href="/research" class="font-[Caveat] text-2xl text-ink-muted no-underline hover:text-ink-main hover:bg-transparent transition-colors">Enter the next room</a>
        </div>
      </div>
    </article>

  </main>
</Layout>
