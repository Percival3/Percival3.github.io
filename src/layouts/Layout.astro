---
import '../styles/global.css';
import '../styles/plum-branch.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A minimalist personal website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts for Hand-drawn display text and Serif body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Noto+Serif+SC:wght@300;400;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="antialiased min-h-screen">
    <div class="site-content">
      <slot />
    </div>
    <script is:inline>
      const resetViewportBackground = () => {
        document.documentElement.style.backgroundImage = 'none';
        document.body.style.backgroundImage = 'none';
      };
      document.addEventListener('astro:after-swap', resetViewportBackground);
      document.addEventListener('astro:page-load', resetViewportBackground);
    </script>
  </body>
</html>
