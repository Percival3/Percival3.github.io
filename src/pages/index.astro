---
import Layout from '../layouts/Layout.astro';
import SpringBranchNav from '../components/SpringBranchNav';
---

<Layout title="Zhong Pengchen | Personal Space">
  <main class="home-stage">
    <div class="home-identity">
      <h1 class="font-[Caveat] text-5xl font-bold tracking-wider text-ink-main">Z.PC</h1>
      <p class="font-[Caveat] text-2xl text-ink-muted mt-2">A minimal space</p>
    </div>

    <SpringBranchNav client:load />

    <div class="cyber-glitch cyber-glitch--br" aria-hidden="true">
      <div class="cyber-glitch__body">
        <div class="cyber-glitch__label">GHOST // NET // Error …</div>
      </div>
    </div>
  </main>
</Layout>
