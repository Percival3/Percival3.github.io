---
import Layout from '../../layouts/Layout.astro';
import HandDrawnDivider from '../../components/HandDrawnDivider';
import BackDoor from '../../components/BackDoor.astro';
import { getCollection, render } from 'astro:content';
import {
  blogSlug,
  entryTitleHref,
  formatTimelineDate,
  isLongIntro,
  isPublishedPdf,
  pdfDownloadName,
  resolveBlogPdfUrl,
} from '../../lib/blog';

const allPosts = (await getCollection('blog'))
  .filter(isPublishedPdf)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const items = await Promise.all(
  allPosts.map(async (entry) => {
    const pdfUrl = resolveBlogPdfUrl(entry);
    const long = isLongIntro(entry);
    const rendered = long ? null : await render(entry);
    return {
      entry,
      slug: blogSlug(entry),
      pdfUrl,
      long,
      titleHref: entryTitleHref(entry, pdfUrl),
      downloadName: pdfDownloadName(entry),
      Content: rendered?.Content,
    };
  })
);
---

<Layout title="Blog | Zhong Pengchen">
  <main class="subpage-surface w-full min-h-screen max-w-5xl mx-auto px-6 py-16 relative">
    <BackDoor />

    <div class="blog-page mt-[4.5rem]">
      <header class="blog-hero">
        <p class="blog-kicker">NOTES · MEDITATION</p>
        <h1 class="blog-title">Blog</h1>
        <div class="blog-hero-rule">
          <HandDrawnDivider client:load />
        </div>
      </header>

      {
        items.length === 0 ? (
          <p class="blog-empty">墨迹未干，敬请期待。</p>
        ) : (
          <ol class="timeline">
            {items.map(({ entry, pdfUrl, long, titleHref, downloadName, Content }) => (
              <li class="timeline-item">
                <div class="timeline-rail" aria-hidden="true">
                  <span class="timeline-dot" />
                </div>
                <time class="timeline-date" datetime={entry.data.date}>
                  {formatTimelineDate(entry.data.date)}
                </time>
                <article class="timeline-body">
                  <h2 class="entry-title">
                    <a
                      href={titleHref}
                      target={long ? undefined : '_blank'}
                      rel={long ? undefined : 'noopener noreferrer'}
                    >
                      {entry.data.title}
                    </a>
                  </h2>

                  {pdfUrl && (
                    <p class="entry-actions">
                      <a class="entry-download" href={pdfUrl} download={downloadName}>
                        下载 PDF
                      </a>
                    </p>
                  )}

                  {!long && Content && (
                    <div class="entry-intro prose prose-sm max-w-none">
                      <Content />
                    </div>
                  )}
                </article>
              </li>
            ))}
          </ol>
        )
      }

      <div class="mt-20 mb-8">
        <HandDrawnDivider client:load />
        <div class="text-center mt-8">
          <a
            href="/research"
            class="font-[Caveat] text-2xl text-ink-muted no-underline hover:text-ink-main hover:bg-transparent transition-colors"
          >
            Enter the research
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .blog-hero {
    text-align: center;
    margin-bottom: clamp(2rem, 5vh, 3.2rem);
  }
  @media (min-width: 768px) {
    .blog-hero {
      text-align: left;
      padding-left: 9.5rem;
    }
  }

  .blog-kicker {
    margin: 0;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.36em;
    text-indent: 0.36em;
    color: var(--color-ink-muted);
  }
  .blog-title {
    margin: 0.35em 0 0;
    font-weight: 700;
    font-size: clamp(2.6rem, 7vw, 3.6rem);
    letter-spacing: 0.08em;
    color: var(--color-ink-main);
  }
  .blog-hero-rule {
    margin-top: 0.35rem;
  }
  .blog-hero-rule :global(.my-12) {
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .blog-empty {
    margin: 2rem 0 0;
    padding: 1.1em 1.2em;
    font-family: Caveat, cursive;
    font-size: 1.3rem;
    color: var(--color-ink-muted);
    border: 1px dashed color-mix(in srgb, var(--color-ink-main) 22%, transparent);
  }

  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem 1.25rem;
    padding: 0 0 2.4rem;
    position: relative;
  }

  @media (min-width: 768px) {
    .timeline-item {
      grid-template-columns: 7.5rem 1.25rem 1fr;
      grid-template-areas: 'date rail body';
      column-gap: 0.75rem;
    }
    .timeline-date {
      grid-area: date;
      text-align: right;
      padding-top: 0.35rem;
    }
    .timeline-rail {
      grid-area: rail;
    }
    .timeline-body {
      grid-area: body;
    }
  }

  .timeline-rail {
    display: none;
  }
  @media (min-width: 768px) {
    .timeline-rail {
      display: flex;
      justify-content: center;
      position: relative;
    }
    .timeline-rail::before {
      content: '';
      position: absolute;
      top: 0.55rem;
      bottom: -2.4rem;
      width: 1px;
      background: color-mix(in srgb, var(--color-ink-main) 18%, transparent);
    }
    .timeline-item:last-child .timeline-rail::before {
      bottom: 0;
      height: 0.6rem;
    }
  }

  .timeline-dot {
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 999px;
    background: var(--color-ink-main);
    border: 2px solid color-mix(in srgb, var(--color-bg-paper) 80%, white);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-ink-main) 25%, transparent);
    margin-top: 0.45rem;
    position: relative;
    z-index: 1;
  }

  .timeline-date {
    font-family: ui-monospace, monospace;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
  }

  .entry-title {
    margin: 0;
    font-size: clamp(1.15rem, 2.6vw, 1.4rem);
    font-weight: 700;
    line-height: 1.35;
  }
  .entry-title a {
    color: var(--color-ink-main);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .entry-title a:hover {
    color: var(--color-ink-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight);
    text-underline-offset: 4px;
  }

  .entry-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.1rem;
    margin: 0.55rem 0 0;
  }
  .entry-download {
    font-family: Caveat, cursive;
    font-size: 1.2rem;
    color: var(--color-ink-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-highlight);
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
  .entry-download:hover {
    background: var(--color-highlight);
    color: var(--color-ink-main);
  }

  .entry-intro {
    margin-top: 0.85rem;
    color: var(--color-ink-muted);
  }
  .entry-intro :global(p) {
    margin: 0.4em 0;
  }
</style>
