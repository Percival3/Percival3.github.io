---
import Layout from '../../layouts/Layout.astro';
import HandDrawnDivider from '../../components/HandDrawnDivider';
import BackDoor from '../../components/BackDoor.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<Layout title="Blog | Zhong Pengchen">
  <main class="bg-bg-paper w-full min-h-screen max-w-5xl mx-auto px-6 py-16 relative">
    
    <BackDoor />

    <header class="mb-12 text-center md:text-left md:ml-64">
      <h1 class="text-4xl md:text-5xl font-bold tracking-wide mb-4">Blog / Notes</h1>
      <p class="font-[Caveat] text-2xl text-ink-muted">Thoughts, reflections, and technical notes.</p>
    </header>

    <div class="md:ml-64 mb-12">
      <HandDrawnDivider client:load />
    </div>

    <div class="flex flex-col md:flex-row gap-12 relative">
      
      <!-- Left Sidebar: Browser & Archive -->
      <aside class="w-full md:w-48 shrink-0 flex flex-col gap-10">
        
        <!-- BROWSER Section -->
        <div>
          <h3 class="text-sm font-bold tracking-widest text-ink-muted uppercase mb-4 border-b-2 border-ink-main/10 pb-2 inline-block">Browser</h3>
          <ul class="space-y-3 font-[Caveat] text-xl text-ink-main">
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">All Posts</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Design</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Engineering</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Thoughts</a></li>
          </ul>
        </div>

        <!-- ARCHIVE Section -->
        <div>
          <h3 class="text-sm font-bold tracking-widest text-ink-muted uppercase mb-4 border-b-2 border-ink-main/10 pb-2 inline-block">Archive</h3>
          <ul class="space-y-3 font-[Caveat] text-xl text-ink-main">
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">2026</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">2025</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">2024</a></li>
          </ul>
        </div>
      </aside>

      <!-- Main Content: Articles list -->
      <div class="flex-1 space-y-16 border-l-0 md:border-l-2 md:border-dashed border-ink-main/10 md:pl-12">
        
        {sortedPosts.map((post) => (
          <article class="group relative">
            <div class="absolute -left-12 top-0 bottom-0 w-1 bg-highlight scale-y-0 group-hover:scale-y-100 transition-transform origin-top hidden md:block"></div>
            <time class="font-mono text-sm text-ink-muted">{post.data.date}</time>
            <h2 class="text-2xl font-bold mt-2 mb-3">
              <a href={`/blog/${post.id}`} class="hover:text-ink-muted transition-colors">{post.data.title}</a>
            </h2>
            <p class="text-ink-muted leading-relaxed">
              {post.data.description}
            </p>
            <a href={`/blog/${post.id}`} class="inline-block mt-4 font-[Caveat] text-xl underline decoration-highlight decoration-2 underline-offset-4 hover:bg-highlight transition-colors">
              Read more
            </a>
          </article>
        ))}

      </div>

    </div>

  </main>
</Layout>
