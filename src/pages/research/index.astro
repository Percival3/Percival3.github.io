---
import Layout from '../../layouts/Layout.astro';
import HandDrawnDivider from '../../components/HandDrawnDivider';
import { getCollection } from 'astro:content';

const allResearch = await getCollection('research');
const sortedResearch = allResearch.sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Research | Zhong Pengchen">
  <main class="w-full min-h-screen max-w-5xl mx-auto px-6 py-16 relative">
    
    <!-- Back / Door icon -->
    <a href="/" class="group absolute top-8 left-0 md:-left-8 flex flex-col items-center justify-center transition-transform hover:-translate-x-2 z-10">
      <div class="w-8 h-12 border-2 border-ink-main border-b-0 relative bg-bg-paper">
        <div class="absolute right-1 top-1/2 w-1 h-1 bg-ink-main rounded-full"></div>
      </div>
      <span class="font-[Caveat] text-lg text-ink-muted mt-1 opacity-0 group-hover:opacity-100 transition-opacity">Return</span>
    </a>

    <header class="mb-12 text-center md:text-left md:ml-64">
      <h1 class="text-4xl md:text-5xl font-bold tracking-wide mb-4">Research / 学术</h1>
      <p class="font-[Caveat] text-2xl text-ink-muted">Publications, preprints, and working papers.</p>
    </header>

    <div class="md:ml-64 mb-12">
      <HandDrawnDivider client:load />
    </div>

    <div class="flex flex-col md:flex-row gap-12 relative">
      
      <!-- Left Sidebar: Filter -->
      <aside class="w-full md:w-48 shrink-0 flex flex-col gap-10">
        <div>
          <h3 class="text-sm font-bold tracking-widest text-ink-muted uppercase mb-4 border-b-2 border-ink-main/10 pb-2 inline-block">Filter</h3>
          <ul class="space-y-3 font-[Caveat] text-xl text-ink-main">
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">All</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Journal Papers</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Conference</a></li>
            <li><a href="#" class="hover:text-ink-muted hover:underline decoration-highlight decoration-2 underline-offset-4 transition-all">Working Papers</a></li>
          </ul>
        </div>
      </aside>

      <!-- Main Content: Publications list -->
      <div class="flex-1 space-y-16 border-l-0 md:border-l-2 md:border-dashed border-ink-main/10 md:pl-12">
        
        {sortedResearch.map((item) => (
          <article class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 md:gap-6 group relative">
            <div class="absolute -left-12 top-0 bottom-0 w-1 bg-highlight scale-y-0 group-hover:scale-y-100 transition-transform origin-top hidden md:block"></div>
            
            <div class="font-mono text-xl text-ink-muted md:text-right pt-1">{item.data.year}</div>
            
            <div class="relative">
              <div class="inline-block border border-ink-main/20 rounded px-2 py-1 text-xs font-mono text-ink-muted mb-3 group-hover:border-ink-main/60 transition-colors">{item.data.venue}</div>
              <h2 class="text-2xl font-bold mb-3">
                <a href={`/research/${item.id}`} class="hover:text-ink-muted transition-colors">{item.data.title}</a>
              </h2>
              <p class="text-ink-muted leading-relaxed mb-4">
                {item.data.abstract}
              </p>
              <div class="flex items-center gap-4">
                {item.data.pdfUrl && (
                  <a href={item.data.pdfUrl} class="font-[Caveat] text-xl underline decoration-highlight decoration-2 underline-offset-4 hover:bg-highlight transition-colors flex items-center gap-1">
                    [PDF]
                  </a>
                )}
                {item.data.codeUrl && (
                  <a href={item.data.codeUrl} class="font-[Caveat] text-xl underline decoration-highlight decoration-2 underline-offset-4 hover:bg-highlight transition-colors flex items-center gap-1">
                    [Code]
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}

      </div>

    </div>

  </main>
</Layout>
