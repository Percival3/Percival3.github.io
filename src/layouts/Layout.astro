---
import '../styles/global.css';
import '../styles/plum-branch.css';
import '../styles/cyber-glitch.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="A minimalist personal website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts for Hand-drawn display text and Serif body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Noto+Serif+SC:wght@300;400;700&display=swap" rel="stylesheet">
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class:list={['antialiased', 'min-h-screen', isHome ? 'is-home' : 'is-subpage']}>
    <!-- WebGL water surface (jquery.ripples-style); canvas mounted by grove-water-init -->
    <div class="grove-water" aria-hidden="true"></div>
    <div class="site-content">
      <slot />
    </div>
    <div class="cyber-glitch cyber-glitch--br" aria-hidden="true">
      <div class="cyber-glitch__body">
        <div class="cyber-glitch__label">GHOST // NET // Error …</div>
      </div>
    </div>
    <script is:inline>
      const resetViewportChrome = () => {
        document.documentElement.style.backgroundImage = 'none';
        document.body.style.backgroundImage = 'none';
        document.documentElement.style.overflow = '';
        document.body.style.overflow = '';
        const home = location.pathname === '/' || location.pathname === '';
        document.body.classList.toggle('is-home', home);
        document.body.classList.toggle('is-subpage', !home);
      };
      document.addEventListener('astro:after-swap', resetViewportChrome);
      document.addEventListener('astro:page-load', resetViewportChrome);
    </script>
    <script>
      import '../scripts/grove-water-init';
    </script>
  </body>
</html>
